.chat-container { height: 100vh; display: flex; flex-direction: column; background: #f5f5f5; }
.chat-list { flex: 1; padding: 20rpx; }
.msg-box { margin-bottom: 20rpx; display: flex; }
.user { justify-content: flex-end; }
.content { padding: 15rpx 25rpx; border-radius: 10rpx; max-width: 70%; font-size: 28rpx; }
.user .content { background: #95ec69; }
.ai .content { background: #fff; }
.input-area { display: flex; padding: 20rpx; background: #fff; border-top: 1rpx solid #ddd; }
input { flex: 1; height: 70rpx; border: 1rpx solid #ddd; padding: 0 20rpx; border-radius: 10rpx; }
button { width: 150rpx !important; height: 70rpx; font-size: 28rpx; margin-left: 20rpx; background: #07c160; color: #fff; padding: 0; line-height: 70rpx; }