.agreement-page {
  background: #f8fbf8;
  padding: 30rpx;
}

.agreement-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(46, 90, 66, 0.06);
}

.agreement-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2e5a42;
}

.agreement-update {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8aa08d;
}

.agreement-intro {
  margin-top: 28rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #333333;
}

.section-item {
  margin-top: 32rpx;
}

.section-heading {
  font-size: 30rpx;
  font-weight: 600;
  color: #2e5a42;
  margin-bottom: 16rpx;
}

.section-body {
  font-size: 27rpx;
  line-height: 1.9;
  color: #4a4a4a;
  white-space: pre-wrap;
}
