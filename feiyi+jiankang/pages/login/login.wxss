.login-container {
  background-color: #F2F6F0;
  min-height: 100vh;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  font-size: 56rpx;
  color: #2E5A42;
  font-weight: bold;
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #7A8F79;
}

.card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(46, 90, 66, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.btn-primary {
  width: 100%;
  background-color: #2E5A42;
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  padding: 28rpx 0;
  box-shadow: 0 10rpx 20rpx rgba(46, 90, 66, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-wechat {
  gap: 16rpx;
}

.btn-icon {
  display: flex;
  align-items: center;
}

.wechat-icon {
  width: 48rpx;
  height: 48rpx;
  position: relative;
}

.wechat-circle {
  width: 100%;
  height: 100%;
  background: #fff;
  border-radius: 50%;
}

.wechat-inner {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 32rpx;
  height: 32rpx;
}

.wechat-left,
.wechat-right {
  position: absolute;
  background: #2E5A42;
  border-radius: 50%;
}

.wechat-left {
  width: 16rpx;
  height: 16rpx;
  top: 4rpx;
  left: 0;
}

.wechat-right {
  width: 12rpx;
  height: 12rpx;
  top: 8rpx;
  right: 0;
}

.btn-secondary {
  width: 100%;
  background: transparent;
  color: #2E5A42;
  border: 2rpx solid #2E5A42;
  border-radius: 40rpx;
  font-size: 30rpx;
  padding: 26rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary::after {
  border: none;
}

.footer {
  margin-top: 80rpx;
  text-align: center;
}

.policy-links {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.policy-link {
  font-size: 24rpx;
  color: #999999;
}

.policy-divider {
  font-size: 24rpx;
  color: #DDDDDD;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  padding: 40rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.modal-list {
  padding: 20rpx 0;
}

.modal-item {
  display: flex;
  align-items: center;
  padding: 30rpx 40rpx;
}

.modal-item:active {
  background-color: #F5F5F5;
}

.avatar-preview {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-size: cover;
  background-position: center;
  margin-right: 20rpx;
}

.modal-item-text {
  font-size: 30rpx;
  color: #333333;
}

.modal-cancel {
  text-align: center;
  padding: 30rpx 0;
  border-top: 1rpx solid #EEEEEE;
  color: #999999;
  font-size: 30rpx;
}

.modal-cancel:active {
  background-color: #F5F5F5;
}

.nickname-modal {
  width: 70%;
}

.nickname-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.nickname-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-size: cover;
  background-position: center;
  margin-bottom: 20rpx;
}

.nickname-input {
  width: 100%;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #EEEEEE;
}

.modal-actions {
  display: flex;
  border-top: 1rpx solid #EEEEEE;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 30rpx;
}

.modal-btn.cancel {
  color: #999999;
  border-right: 1rpx solid #EEEEEE;
}

.modal-btn.confirm {
  color: #2E5A42;
}

.modal-btn:active {
  background-color: #F5F5F5;
}
