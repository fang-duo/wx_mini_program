<view class="container login-container">
  <view class="header">
    <view class="title">欢迎进入遗韵养生</view>
    <view class="subtitle">传承非遗，守护健康</view>
  </view>

  <view class="card">
    <button class="btn-primary btn-wechat" bindtap="handleLogin" loading="{{loading}}" disabled="{{loading}}">
      <text class="btn-icon">
        <text class="icon-wechat">
          <view class="wechat-icon">
            <view class="wechat-circle"></view>
            <view class="wechat-inner">
              <view class="wechat-left"></view>
              <view class="wechat-right"></view>
            </view>
          </view>
        </text>
      </text>
      微信一键进入
    </button>

    <button class="btn-secondary" bindtap="handleSkip" loading="{{loading}}" disabled="{{loading}}">
      稍后完善资料
    </button>
  </view>

  <view class="footer">
    <view class="policy-links">
      <text class="policy-link" bindtap="openPrivacy">隐私政策</text>
      <text class="policy-divider">|</text>
      <text class="policy-link" bindtap="openAgreement">用户协议</text>
    </view>
  </view>
</view>

<view class="modal-overlay" wx:if="{{showAvatarModal}}" bindtap="cancelAvatarModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-title">选择头像</view>
    <view class="modal-list">
      <view class="modal-item" bindtap="selectWechatAvatar" wx:if="{{userInfo.avatarUrl}}">
        <view class="avatar-preview" style="background-image: url({{userInfo.avatarUrl}})"></view>
        <text class="modal-item-text">用微信头像</text>
      </view>
      <view class="modal-item" bindtap="selectFromAlbum">
        <text class="modal-item-text">从相册选择</text>
      </view>
      <view class="modal-item" bindtap="takePhoto">
        <text class="modal-item-text">拍照</text>
      </view>
    </view>
    <view class="modal-cancel" bindtap="cancelAvatarModal">
      <text>取消</text>
    </view>
  </view>
</view>

<view class="modal-overlay" wx:if="{{showNicknameModal}}" bindtap="cancelNicknameModal">
  <view class="modal-content nickname-modal" catchtap="stopPropagation">
    <view class="modal-title">设置昵称</view>
    <view class="nickname-preview">
      <view class="nickname-avatar" style="background-image: url({{userInfo.avatarUrl}})"></view>
      <input class="nickname-input" placeholder="请输入昵称" value="{{userInfo.nickname}}" bindinput="onNicknameInput" maxlength="20" />
    </view>
    <view class="modal-actions">
      <view class="modal-btn cancel" bindtap="cancelNicknameModal">取消</view>
      <view class="modal-btn confirm" bindtap="confirmNickname">确认</view>
    </view>
  </view>
</view>