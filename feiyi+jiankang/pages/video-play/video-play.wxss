.video-container {
  display: flex;
  flex-direction: column;
  background-color: #f8f8f8;
  height: 100vh;
}

.video-player {
  width: 100%;
  height: 420rpx;
  background-color: #000000;
}

.video-info {
  padding: 30rpx;
  background-color: #ffffff;
}

.video-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.video-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.error-text {
  color: #c84b31;
}
