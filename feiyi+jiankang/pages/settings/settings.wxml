<view class="container">
  <view class="settings-group">
    <view class="settings-item">
      <text class="label">消息通知</text>
      <switch checked="{{notify}}" color="#2E5A42" bindchange="switchChange" data-type="notify" />
    </view>
  </view>

  <view class="settings-group">
    <view class="settings-item" bindtap="clearCache">
      <text class="label">清除缓存</text>
      <view class="right-info">
        <text class="desc">{{cacheSize}}</text>
        <text class="arrow">></text>
      </view>
    </view>
    <view class="settings-item" bindtap="checkUpdate">
      <text class="label">检查更新</text>
      <view class="right-info">
        <text class="desc">v1.0.0</text>
        <text class="arrow">></text>
      </view>
    </view>
    <view class="settings-item" bindtap="showAbout">
      <text class="label">关于遗韵养生</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="btn-wrap">
    <button class="btn-logout" bindtap="logout">退出登录</button>
  </view>
</view>
