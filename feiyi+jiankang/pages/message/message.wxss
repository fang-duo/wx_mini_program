.container {
  background-color: #F8FBF8;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* 顶部操作栏 */
.header-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.select-all {
  display: flex;
  align-items: center;
}

.select-all text {
  font-size: 28rpx;
  margin-left: 10rpx;
  color: #666;
}

.mode-switch {
  font-size: 28rpx;
  color: #2E5A42;
  font-weight: 500;
}

.message-list {
  padding: 20rpx 30rpx;
}

.message-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  transition: all 0.3s;
  border: 2rpx solid transparent;
}

.message-item.selected {
  border-color: #2E5A42;
  background: #F2F9F5;
}

.select-icon {
  margin-right: 20rpx;
}

.msg-body {
  flex: 1;
}

.msg-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.msg-date {
  font-size: 24rpx;
  color: #999;
}

.fav-btn {
  padding: 10rpx;
}

.fav-icon {
  font-size: 36rpx;
  color: #ccc;
}

.fav-icon.active {
  color: #FFB800;
}

.msg-question, .msg-answer {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.msg-answer {
  margin-bottom: 0;
  background: #F8FBF8;
  padding: 16rpx;
  border-radius: 12rpx;
}

.q-icon, .a-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 6rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  margin-top: 6rpx;
}

.q-icon {
  background: #7A8F79;
}

.a-icon {
  background: #2E5A42;
}

.q-text, .a-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  color: #DDEBE1;
  margin-bottom: 30rpx;
}

.btn-go-ai {
  margin-top: 40rpx;
  background: #2E5A42;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  width: 240rpx;
}

/* 底部批量操作栏 */
.batch-bar {
  position: fixed;
  bottom: -120rpx;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 40rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.1);
  transition: bottom 0.3s;
  z-index: 100;
}

.batch-bar.show {
  bottom: 0;
}

.batch-info {
  font-size: 28rpx;
  color: #333;
}

.btn-delete-batch {
  background: #E05D5D;
  color: #fff;
  font-size: 26rpx;
  border-radius: 30rpx;
  padding: 0 40rpx;
  height: 60rpx;
  line-height: 60rpx;
  margin: 0;
}
