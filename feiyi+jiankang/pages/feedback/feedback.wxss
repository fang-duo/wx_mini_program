.container {
  background-color: #F8FBF8;
  min-height: 100vh;
  padding: 30rpx;
}

.form-box {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
  margin-bottom: 40rpx;
}

.title {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.feedback-input {
  width: 100%;
  height: 240rpx;
  background: #F2F6F0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.word-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.contact-box {
  display: flex;
  align-items: center;
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 2rpx solid #F2F6F0;
}

.label {
  font-size: 28rpx;
  color: #666;
}

.input {
  flex: 1;
  font-size: 28rpx;
}

.btn-submit {
  background-color: #E8F4EC;
  color: #7A8F79;
  border-radius: 40rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
  margin-bottom: 60rpx;
}

.btn-submit.active {
  background-color: #2E5A42;
  color: #fff;
  box-shadow: 0 10rpx 20rpx rgba(46, 90, 66, 0.2);
}

.faq-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.faq-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2E5A42;
  margin-bottom: 20rpx;
}

.faq-item {
  border-bottom: 2rpx solid #F2F6F0;
  padding: 20rpx 0;
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-q {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.q-icon {
  background: #7A8F79;
  color: #fff;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6rpx;
  font-size: 22rpx;
  margin-right: 16rpx;
}

.arrow {
  margin-left: auto;
  color: #CCC;
  font-family: monospace;
  transition: transform 0.3s;
}

.arrow.up {
  transform: rotate(90deg);
}

.faq-a {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-top: 20rpx;
  padding-left: 52rpx;
  background: #F8FBF8;
  padding: 20rpx;
  border-radius: 12rpx;
}