<view class="container">
  <view class="browse-banner" wx:if="{{isBrowseOnly}}">
    <view class="browse-banner-title">当前为基础浏览模式</view>
    <view class="browse-banner-desc">你仍可浏览首页、分类和详情内容；同意隐私政策后可使用 AI、打卡、登录和收藏等功能。</view>
    <view class="browse-banner-actions">
      <text class="banner-link" bindtap="openAgreement">查看隐私政策</text>
      <text class="banner-link primary" bindtap="enableFullFeatures">同意并开启完整功能</text>
    </view>
  </view>

  <!-- 顶部 Banner/轮播图 -->
  <swiper class="banner" wx:if="{{banners.length > 0}}" indicator-dots="{{true}}" autoplay="{{true}}" circular="{{true}}" indicator-color="rgba(255, 255, 255, 0.6)" indicator-active-color="#2E5A42">
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <view class="banner-item bg-secondary">
        <image class="banner-img" src="{{item.img}}" mode="aspectFill" wx:if="{{item.img}}" />
        <view class="banner-text">{{item.title}}</view>
      </view>
    </swiper-item>
  </swiper>
  <view class="empty-panel" wx:elif="{{!loadingHomeContent}}">
    <view class="empty-panel-title">当前暂无精选内容</view>
    <view class="empty-panel-desc">精选内容将根据活动安排持续更新，请稍后查看。</view>
  </view>

  <!-- 四大分类模块 -->
  <view class="section">
    <view class="section-title">非遗传承</view>
    <view class="category-grid">
      <view class="category-item" wx:for="{{categories}}" wx:key="id" bindtap="goToCategory" data-id="{{item.id}}">
        <view class="icon-wrap">
          <text class="iconfont">{{item.iconText}}</text>
        </view>
        <text class="category-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 每日推荐 (可选加分) -->
  <view class="section recommend-daily">
    <view class="section-title">每日推荐</view>
    <view class="daily-card" wx:if="{{dailyRecommend}}">
      <view class="daily-title">{{dailyRecommend.title || '今日养生建议'}}</view>
      <view class="daily-desc">{{dailyRecommend.summary || '当前推荐内容请以页面展示信息为准。'}}</view>
      <view class="daily-btn" bindtap="goToDetail" data-title="{{dailyRecommend.title}}" data-item-id="{{dailyRecommend.id}}" data-content-type="{{dailyRecommend.contentType}}">去练习 ></view>
    </view>
    <view class="section-empty" wx:else>当前暂无每日推荐内容。</view>
  </view>

  <!-- 最新活动与宣传 -->
  <view class="section">
    <view class="section-title">最新活动与宣传</view>
    <view class="article-list" wx:if="{{articles.length > 0}}">
      <view class="article-item" wx:for="{{articles}}" wx:key="id" bindtap="goToDetail" data-title="{{item.title}}" data-item-id="{{item.id}}" data-content-type="{{item.contentType}}">
        <image class="article-img" src="{{item.cover}}" mode="aspectFill" wx:if="{{item.cover}}"></image>
        <view class="article-info">
          <view class="article-title">{{item.title}}</view>
          <view class="article-desc">{{item.desc}}</view>
          <view class="article-meta">
            <text class="tag">{{item.tag}}</text>
            <text class="date">{{item.date}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="section-empty" wx:else>当前暂无活动内容。</view>
  </view>

  <view class="privacy-mask" wx:if="{{showPrivacyDialog}}">
    <view class="privacy-dialog">
      <view class="privacy-title">隐私保护提示</view>
      <view class="privacy-content">
        欢迎使用非遗健康小程序。为了向你提供内容浏览、AI 问答、健康打卡、收藏和设置同步等服务，我们会按照《隐私政策》规范处理相关信息，请在使用前仔细阅读。
      </view>
      <view class="privacy-link-row">
        <text class="privacy-link" bindtap="openAgreement">查看《隐私政策》全文</text>
      </view>
      <button class="privacy-btn privacy-btn-primary" bindtap="acceptPrivacy">同意并继续</button>
      <button class="privacy-btn privacy-btn-secondary" bindtap="declinePrivacy">不同意，仅浏览</button>
    </view>
  </view>
</view>
