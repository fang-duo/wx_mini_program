.container {
  background-color: #F8FBF8;
  min-height: 100vh;
  padding: 30rpx;
}

.form-group {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 0 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #F2F6F0;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 30rpx;
  color: #333;
  width: 120rpx;
}

.input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: #666;
}

.avatar-box {
  display: flex;
  align-items: center;
}

.avatar-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #E8F4EC;
}

.default-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #2E5A42;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.arrow {
  color: #CCC;
  font-size: 28rpx;
  margin-left: 20rpx;
  font-family: monospace;
}

.btn-wrap {
  margin-top: 80rpx;
}

.btn-save {
  background-color: #2E5A42;
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
  box-shadow: 0 10rpx 20rpx rgba(46, 90, 66, 0.2);
}